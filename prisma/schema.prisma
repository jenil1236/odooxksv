generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PROCUREMENT_OFFICER
  MANAGER_APPROVER
  VENDOR
}

enum VendorStatus {
  PENDING
  ACTIVE
  BLOCKED
  INACTIVE
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  details     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  vendors     Vendor[]
}

model User {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  email          String         @unique
  passwordHash   String
  phone          String?
  country        String?
  additionalInfo String?
  role           Role           @default(PROCUREMENT_OFFICER)
  isActive       Boolean        @default(true)
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // Relations to new modules
  vendor         Vendor?
  notifications  Notification[]
  activityLogs   ActivityLog[]
}

model VendorCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendors     Vendor[]
}

model Vendor {
  id             String          @id @default(cuid())
  companyName    String
  gstNumber      String?
  contactName    String
  contactEmail   String          @unique
  contactPhone   String?
  address        String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  status         VendorStatus    @default(PENDING)
  rating         Float           @default(0.0)
  isActive       Boolean         @default(true)
  notes          String?
  
  // Relationship to the User login record
  userId         String?         @unique
  user           User?           @relation(fields: [userId], references: [id])
  
  // Relationship to Organization
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  
  // Relationship to Category
  categoryId     String?
  category       VendorCategory? @relation(fields: [categoryId], references: [id])
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}
